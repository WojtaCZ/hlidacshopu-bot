# --- Platform selection ---
# Set to "telegram" or "discord"
BOT_PLATFORM=telegram

# --- Telegram settings ---
# Get this from @BotFather on Telegram
TELEGRAM_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Optional: restrict bot to your chat ID only (get it from /start command)
# Leave empty to allow anyone
ALLOWED_CHAT_IDS=

# --- Discord settings ---
# Get this from https://discord.com/developers/applications
DISCORD_TOKEN=

# Optional: restrict bot to specific user IDs (comma-separated)
ALLOWED_USER_IDS=

# Optional: restrict bot to specific channel IDs (comma-separated)
ALLOWED_CHANNEL_IDS=

# Optional: channel ID for startup notifications
NOTIFICATION_CHANNEL_ID=

# --- Shared settings ---
# Check interval in seconds (default: 3600 = 1 hour)
CHECK_INTERVAL=3600

# Minimum price drop % to notify (default: 0 = any drop)
DROP_THRESHOLD=0
